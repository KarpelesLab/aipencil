{
  "width": 600,
  "height": 400,
  "padding": 0,
  "background": "#87CEEB",
  "defs": {
    "sun": {
      "params": {
        "color": {"type": "color", "default": "#FFD700"},
        "size": {"type": "number", "default": 45}
      },
      "width": 130,
      "height": 130,
      "elements": [
        {"type": "circle", "x": 65, "y": 65, "r": 45, "style": {"fill": "{{color}}"}},
        {"type": "line", "x": 65, "y": 5, "x2": 65, "y2": -10, "style": {"stroke": "{{color}}", "strokeWidth": 3, "strokeLinecap": "round"}},
        {"type": "line", "x": 65, "y": 125, "x2": 65, "y2": 140, "style": {"stroke": "{{color}}", "strokeWidth": 3, "strokeLinecap": "round"}},
        {"type": "line", "x": 5, "y": 65, "x2": -10, "y2": 65, "style": {"stroke": "{{color}}", "strokeWidth": 3, "strokeLinecap": "round"}},
        {"type": "line", "x": 125, "y": 65, "x2": 140, "y2": 65, "style": {"stroke": "{{color}}", "strokeWidth": 3, "strokeLinecap": "round"}},
        {"type": "line", "x": 23, "y": 23, "x2": 12, "y2": 12, "style": {"stroke": "{{color}}", "strokeWidth": 3, "strokeLinecap": "round"}},
        {"type": "line", "x": 107, "y": 23, "x2": 118, "y2": 12, "style": {"stroke": "{{color}}", "strokeWidth": 3, "strokeLinecap": "round"}},
        {"type": "line", "x": 23, "y": 107, "x2": 12, "y2": 118, "style": {"stroke": "{{color}}", "strokeWidth": 3, "strokeLinecap": "round"}},
        {"type": "line", "x": 107, "y": 107, "x2": 118, "y2": 118, "style": {"stroke": "{{color}}", "strokeWidth": 3, "strokeLinecap": "round"}}
      ]
    },
    "cloud": {
      "params": {},
      "width": 100,
      "height": 50,
      "elements": [
        {"type": "ellipse", "x": 50, "y": 30, "rx": 40, "ry": 20, "style": {"fill": "#fff"}},
        {"type": "ellipse", "x": 70, "y": 22, "rx": 35, "ry": 22, "style": {"fill": "#fff"}},
        {"type": "ellipse", "x": 30, "y": 25, "rx": 30, "ry": 18, "style": {"fill": "#fff"}}
      ]
    },
    "flower": {
      "params": {
        "petalColor": {"type": "color", "default": "#FF5722"},
        "centerColor": {"type": "color", "default": "#FFC107"}
      },
      "width": 12,
      "height": 30,
      "elements": [
        {"type": "path", "d": "M 6 15 L 6 30", "style": {"fill": "none", "stroke": "#388E3C", "strokeWidth": 2}},
        {"type": "circle", "x": 6, "y": 10, "r": 5, "style": {"fill": "{{petalColor}}"}},
        {"type": "circle", "x": 6, "y": 10, "r": 2, "style": {"fill": "{{centerColor}}"}}
      ]
    },
    "grass-tuft": {
      "params": {},
      "width": 20,
      "height": 20,
      "elements": [
        {"type": "path", "d": "M 0 20 Q 5 5 10 20", "style": {"fill": "none", "stroke": "#2E7D32", "strokeWidth": 1.5}},
        {"type": "path", "d": "M 10 20 Q 15 5 20 20", "style": {"fill": "none", "stroke": "#2E7D32", "strokeWidth": 1.5}}
      ]
    },
    "window": {
      "params": {},
      "width": 22,
      "height": 22,
      "elements": [
        {"type": "rect", "x": 0, "y": 0, "width": 22, "height": 22, "style": {"fill": "#BBDEFB", "stroke": "#5D4037", "strokeWidth": 1.5}},
        {"type": "line", "x": 11, "y": 0, "x2": 11, "y2": 22, "style": {"stroke": "#5D4037", "strokeWidth": 1}},
        {"type": "line", "x": 0, "y": 11, "x2": 22, "y2": 11, "style": {"stroke": "#5D4037", "strokeWidth": 1}}
      ]
    },
    "house": {
      "params": {
        "wallColor": {"type": "color", "default": "#E57373"},
        "roofColor": {"type": "color", "default": "#D32F2F"}
      },
      "width": 140,
      "height": 130,
      "elements": [
        {"type": "polygon", "points": [[0, 45], [70, 0], [140, 45]], "style": {"fill": "{{roofColor}}", "stroke": "#B71C1C", "strokeWidth": 2}},

        {"type": "rect", "x": 20, "y": 40, "width": 100, "height": 80, "style": {"fill": "{{wallColor}}", "stroke": "#C62828", "strokeWidth": 2}},

        {"type": "rect", "x": 60, "y": 7, "width": 18, "height": 30, "style": {"fill": "#9E9E9E", "stroke": "#616161", "strokeWidth": 1.5}},
        {"type": "rect", "x": 62, "y": 5, "width": 14, "height": 4, "style": {"fill": "#757575"}},

        {"type": "use", "pattern": "window", "x": 32, "y": 55},
        {"type": "use", "pattern": "window", "x": 90, "y": 55},

        {"type": "rect", "x": 55, "y": 85, "width": 25, "height": 35, "style": {"fill": "#795548", "stroke": "#4E342E", "strokeWidth": 1.5}},
        {"type": "circle", "x": 73, "y": 103, "r": 2, "style": {"fill": "#FFD700"}}
      ]
    }
  },
  "elements": [
    {
      "type": "viewport",
      "width": 600, "height": 400,
      "padding": 0,
      "clip": true,
      "viewBox": {"x": 0, "y": 0, "width": 600, "height": 400},
      "layers": [
        {
          "id": "sky", "zIndex": 0,
          "elements": [
            {"type": "use", "pattern": "sun", "position": {"x": "75%", "y": "0", "anchor": "top-center"}},
            {"type": "use", "pattern": "cloud", "position": {"x": "15%", "y": "60"}},
            {"type": "use", "pattern": "cloud", "position": {"x": "55%", "y": "35"}}
          ]
        },
        {
          "id": "hills", "zIndex": 10,
          "elements": [
            {"type": "path", "d": "M 0 300 Q 150 200 300 240 Q 450 190 600 260 L 600 400 L 0 400 Z", "style": {"fill": "#4CAF50"}},
            {"type": "path", "d": "M 0 340 Q 100 310 200 330 Q 350 290 500 310 Q 550 305 600 320 L 600 400 L 0 400 Z", "style": {"fill": "#388E3C"}}
          ]
        },
        {
          "id": "objects", "zIndex": 20,
          "elements": [
            {"type": "use", "pattern": "house", "position": {"x": "38%", "y": "165", "anchor": "top-center"}},

            {"type": "use", "pattern": "flower", "params": {"petalColor": "#FF5722"}, "position": {"x": "20%", "y": "305"}},
            {"type": "use", "pattern": "flower", "params": {"petalColor": "#E91E63"}, "position": {"x": "24%", "y": "300"}},
            {"type": "use", "pattern": "flower", "params": {"petalColor": "#9C27B0"}, "position": {"x": "78%", "y": "285"}},

            {"type": "use", "pattern": "grass-tuft", "position": {"x": "12%", "y": "295"}},
            {"type": "use", "pattern": "grass-tuft", "position": {"x": "73%", "y": "255"}},
            {"type": "use", "pattern": "grass-tuft", "position": {"x": "7%", "y": "365"}},
            {"type": "use", "pattern": "grass-tuft", "position": {"x": "27%", "y": "360"}},
            {"type": "use", "pattern": "grass-tuft", "position": {"x": "65%", "y": "355"}},
            {"type": "use", "pattern": "grass-tuft", "position": {"x": "85%", "y": "360"}}
          ]
        }
      ]
    }
  ]
}
