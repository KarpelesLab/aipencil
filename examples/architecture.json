{
  "background": "#fafafa",
  "padding": 30,
  "styles": {
    "frontend": {"fill": "#e3f2fd", "stroke": "#1565c0", "strokeWidth": 2, "rx": 12},
    "backend": {"fill": "#fce4ec", "stroke": "#c62828", "strokeWidth": 2, "rx": 12},
    "data": {"fill": "#fff3e0", "stroke": "#e65100", "strokeWidth": 2, "rx": 12},
    "external": {"fill": "#e8f5e9", "stroke": "#2e7d32", "strokeWidth": 2, "rx": 12}
  },
  "elements": [
    {
      "type": "group",
      "layout": {"type": "column", "gap": 20, "align": "center"},
      "children": [
        {"type": "text", "text": "E-Commerce Platform Architecture",
         "align": "center", "style": {"fontSize": 22, "fontWeight": "bold", "fill": "#333"}},
        {"type": "text", "text": "Production deployment overview",
         "align": "center", "style": {"fontSize": 12, "fill": "#888"}}
      ]
    },
    {
      "type": "group",
      "layout": {"type": "ranked", "gap": 55, "align": "LR"},
      "children": [
        {"id": "web", "type": "group", "layout": {"type": "stack"}, "children": [
          {"type": "rect", "class": "frontend"},
          {"type": "text", "text": "Web App\n(React)", "align": "center", "style": {"fontSize": 13}}
        ]},
        {"id": "mobile", "type": "group", "layout": {"type": "stack"}, "children": [
          {"type": "rect", "class": "frontend"},
          {"type": "text", "text": "Mobile App\n(React Native)", "align": "center", "style": {"fontSize": 13}}
        ]},
        {"id": "gateway", "type": "group", "layout": {"type": "stack"}, "children": [
          {"type": "rect", "class": "backend"},
          {"type": "text", "text": "API Gateway\n(Kong)", "align": "center", "style": {"fontSize": 13}}
        ]},
        {"id": "auth", "type": "group", "layout": {"type": "stack"}, "children": [
          {"type": "rect", "class": "backend"},
          {"type": "text", "text": "Auth", "align": "center", "style": {"fontSize": 13}}
        ]},
        {"id": "catalog", "type": "group", "layout": {"type": "stack"}, "children": [
          {"type": "rect", "class": "backend"},
          {"type": "text", "text": "Catalog", "align": "center", "style": {"fontSize": 13}}
        ]},
        {"id": "orders", "type": "group", "layout": {"type": "stack"}, "children": [
          {"type": "rect", "class": "backend"},
          {"type": "text", "text": "Orders", "align": "center", "style": {"fontSize": 13}}
        ]},
        {"id": "payments", "type": "group", "layout": {"type": "stack"}, "children": [
          {"type": "rect", "class": "backend"},
          {"type": "text", "text": "Payments", "align": "center", "style": {"fontSize": 13}}
        ]},
        {"id": "postgres", "type": "group", "layout": {"type": "stack"}, "children": [
          {"type": "rect", "class": "data"},
          {"type": "text", "text": "PostgreSQL", "align": "center", "style": {"fontSize": 13}}
        ]},
        {"id": "redis", "type": "group", "layout": {"type": "stack"}, "children": [
          {"type": "rect", "class": "data"},
          {"type": "text", "text": "Redis Cache", "align": "center", "style": {"fontSize": 13}}
        ]},
        {"id": "s3", "type": "group", "layout": {"type": "stack"}, "children": [
          {"type": "rect", "class": "data"},
          {"type": "text", "text": "S3 Storage", "align": "center", "style": {"fontSize": 13}}
        ]},
        {"id": "stripe", "type": "group", "layout": {"type": "stack"}, "children": [
          {"type": "rect", "class": "external"},
          {"type": "text", "text": "Stripe API", "align": "center", "style": {"fontSize": 13}}
        ]},
        {"type": "arrow", "from": "web", "to": "gateway", "style": {"stroke": "#1565c0", "strokeWidth": 1.5}},
        {"type": "arrow", "from": "mobile", "to": "gateway", "style": {"stroke": "#1565c0", "strokeWidth": 1.5}},
        {"type": "arrow", "from": "gateway", "to": "auth", "style": {"stroke": "#c62828", "strokeWidth": 1.5}},
        {"type": "arrow", "from": "gateway", "to": "catalog", "style": {"stroke": "#c62828", "strokeWidth": 1.5}},
        {"type": "arrow", "from": "gateway", "to": "orders", "style": {"stroke": "#c62828", "strokeWidth": 1.5}},
        {"type": "arrow", "from": "orders", "to": "payments", "style": {"stroke": "#c62828", "strokeWidth": 1.5}},
        {"type": "arrow", "from": "auth", "to": "redis", "style": {"stroke": "#e65100", "strokeWidth": 1.5}},
        {"type": "arrow", "from": "catalog", "to": "postgres", "style": {"stroke": "#e65100", "strokeWidth": 1.5}},
        {"type": "arrow", "from": "orders", "to": "postgres", "style": {"stroke": "#e65100", "strokeWidth": 1.5}},
        {"type": "arrow", "from": "catalog", "to": "s3", "style": {"stroke": "#e65100", "strokeWidth": 1.5}},
        {"type": "arrow", "from": "payments", "to": "stripe", "style": {"stroke": "#2e7d32", "strokeWidth": 1.5}}
      ]
    }
  ]
}
