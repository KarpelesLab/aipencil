    {"type": "rect", "x": 10, "y": 103, "width": 16, "height": 7, "style": {"fill": "#555", "rx": 2}},
    {"type": "rect", "x": 24, "y": 103, "width": 16, "height": 7, "style": {"fill": "#555", "rx": 2}},

    {"type": "text", "x": 25, "y": 118, "text": "{{label}}", "align": "center", "style": {"fontSize": 10, "fill": "#333"}, "if": "label"}
