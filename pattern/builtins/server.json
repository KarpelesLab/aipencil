{
  "params": {
    "color": {"type": "color", "default": "#ECEFF1"},
    "accentColor": {"type": "color", "default": "#455A64"},
    "label": {"type": "string", "default": ""}
  },
  "width": 60,
  "height": 70,
  "elements": [
    {"type": "rect", "x": 0, "y": 0, "width": 60, "height": 70, "style": {"fill": "{{color}}", "stroke": "{{accentColor}}", "strokeWidth": 2, "rx": 3}},
    {"type": "line", "x": 0, "y": 24, "x2": 60, "y2": 24, "style": {"stroke": "{{accentColor}}", "strokeWidth": 1}},
    {"type": "line", "x": 0, "y": 48, "x2": 60, "y2": 48, "style": {"stroke": "{{accentColor}}", "strokeWidth": 1}},
    {"type": "circle", "x": 50, "y": 12, "r": 3, "style": {"fill": "#4CAF50"}},
    {"type": "circle", "x": 50, "y": 36, "r": 3, "style": {"fill": "#4CAF50"}},
    {"type": "circle", "x": 50, "y": 59, "r": 3, "style": {"fill": "#FFC107"}},
    {"type": "line", "x": 8, "y": 10, "x2": 35, "y2": 10, "style": {"stroke": "{{accentColor}}", "strokeWidth": 2}},
    {"type": "line", "x": 8, "y": 15, "x2": 25, "y2": 15, "style": {"stroke": "{{accentColor}}", "strokeWidth": 2}},
    {"type": "line", "x": 8, "y": 34, "x2": 35, "y2": 34, "style": {"stroke": "{{accentColor}}", "strokeWidth": 2}},
    {"type": "line", "x": 8, "y": 39, "x2": 25, "y2": 39, "style": {"stroke": "{{accentColor}}", "strokeWidth": 2}},
    {"type": "text", "x": 30, "y": 59, "text": "{{label}}", "align": "center", "style": {"fontSize": 8, "fill": "#333"}, "if": "label"}
  ]
}
