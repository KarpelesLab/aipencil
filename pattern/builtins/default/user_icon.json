{
  "params": {
    "color": {"type": "color", "default": "#78909C"},
    "label": {"type": "string", "default": ""}
  },
  "width": 40,
  "height": 50,
  "elements": [
    {"type": "circle", "x": 20, "y": 14, "r": 12, "style": {"fill": "{{color}}"}},
