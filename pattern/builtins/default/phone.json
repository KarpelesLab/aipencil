{
  "params": {
    "color": {"type": "color", "default": "#37474F"},
    "screenColor": {"type": "color", "default": "#BBDEFB"},
    "label": {"type": "string", "default": ""}
  },
  "width": 30,
  "height": 55,
  "elements": [
    {"type": "rect", "x": 2, "y": 0, "width": 26, "height": 50, "style": {"fill": "{{color}}", "stroke": "#263238", "strokeWidth": 1.5, "rx": 4}},
    {"type": "rect", "x": 4, "y": 6, "width": 22, "height": 34, "style": {"fill": "{{screenColor}}", "rx": 1}},
    {"type": "circle", "x": 15, "y": 45, "r": 3, "style": {"fill": "#546E7A", "stroke": "#263238", "strokeWidth": 0.8}},
    {"type": "rect", "x": 10, "y": 2, "width": 10, "height": 2, "style": {"fill": "#546E7A", "rx": 1}},
    {"type": "text", "x": 15, "y": 55, "text": "{{label}}", "align": "center", "style": {"fontSize": 8, "fill": "#333"}, "if": "label"}
  ]
}
