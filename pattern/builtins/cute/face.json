    {"type": "circle", "x": 14, "y": 26, "r": 2.5, "style": {"fill": "#fff"}, "if": "angle == 'left'"},
    {"type": "line", "x": 10, "y": 42, "x2": 20, "y2": 42, "style": {"stroke": "#c48a6a", "strokeWidth": 1.2}, "if": "angle == 'left'"},

    {"type": "path", "d": "M 0 30 Q 0 -2 30 -2 Q 60 -2 60 30 Q 56 38 46 42 L 42 36 Q 36 30 30 36 Q 24 30 18 36 L 14 42 Q 4 38 0 30 Z", "style": {"fill": "{{hairColor}}"}, "if": "angle == 'back'"},

    {"type": "text", "x": 30, "y": 66, "text": "{{label}}", "align": "center", "style": {"fontSize": 9, "fill": "#333"}, "if": "label"}
