    "skinColor": {"type": "color", "default": "#fde8d0"},
    "hairColor": {"type": "color", "default": "#F48FB1"},
    "eyeColor": {"type": "color", "default": "#333"},
    "expression": {"type": "string", "default": "neutral", "enum": ["neutral", "happy", "sad", "surprised"]},
