    {"type": "line", "x": 26, "y": 42, "x2": 34, "y2": 42, "style": {"stroke": "#c48a6a", "strokeWidth": 1.2, "strokeLinecap": "round"}, "if": "angle == 'front' && expression == 'neutral'"},
